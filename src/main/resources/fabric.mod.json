{
	"schemaVersion": 1,
	"id": "better-snowy-leaves",
	"version": "${version}",
	"name": "Better Snowy Leaves",
	"description": "Subtle improvement to snowy leaves, with Stay True compat!",
	"authors": [
		"Fabiofdez"
	],
	"contact": {
		"sources": "https://github.com/Fabiofdez/Better-Snowy-Leaves"
	},
	"license": "CC0-1.0",
	"icon": "assets/better-snowy-leaves/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"fabiofdez.snowyleaves.BetterSnowyLeaves"
		],
		"client": [
			"fabiofdez.snowyleaves.BetterSnowyLeavesClient"
		],
		"fabric-datagen": [
			"fabiofdez.snowyleaves.BetterSnowyLeavesDataGenerator"
		]
	},
	"mixins": [
		"better-snowy-leaves.mixins.json",
		{
			"config": "better-snowy-leaves.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.17.2",
		"minecraft": "~1.21.5",
		"java": ">=21",
		"fabric-api": "*"
	}
}