{
	"schemaVersion": 1,
	"id": "snowyleaves",
	"version": "${version}",
	"name": "Better Snowy Leaves",
	"description": "This is an example description! Tell everyone what your mod is about!",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/snowyleaves/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"fabiofdez.snowyleaves.BetterSnowyLeaves"
		],
		"client": [
			"fabiofdez.snowyleaves.BetterSnowyLeavesClient"
		],
		"fabric-datagen": [
			"fabiofdez.snowyleaves.BetterSnowyLeavesDataGenerator"
		]
	},
	"mixins": [
		"snowyleaves.mixins.json",
		{
			"config": "snowyleaves.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.15.11",
		"minecraft": "~1.20.4",
		"java": ">=17",
		"fabric-api": "*"
	},
	"suggests": {
		"another-mod": "*"
	}
}